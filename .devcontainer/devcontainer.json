{
    "name": "Haskell Dev 9.6.7",
    // "image": "haskell:9.6.7",
    "build": {
        "dockerfile": "Dockerfile"
    },
    "mounts": [
        // 2. Cabal 套件與編譯快取 (包含下載的原始碼與編譯好的庫)
        "source=haskell-cabal-cache,target=/root/.cabal",
        // 3. 專案原始碼同步
        "source=${localWorkspaceFolder},target=/workspace,type=bind"
    ],

    "customizations": {
        "vscode": {
            "settings": {
                "haskell.manageHLS": "PATH"
            },
            "extensions": [
                "haskell.haskell",
                "justusadam.language-haskell",
            ]
        }
    },

    "remoteUser": "root"
}
